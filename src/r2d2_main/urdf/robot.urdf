<?xml version="1.0"?>

<robot name="r2d2">

    <link name="robot_base">
        <visual>
            <origin xyz="0 0 0.25" rpy="0 0 0"/>
            <geometry>
                <box size="0.4 0.4 0.5" />
            </geometry>
        </visual>
        <collision>
             <geometry>
                <box size="0.4 0.4 0.5" />
            </geometry>
        </collision>
    </link>

    <!-- left wheels -->
    <link name="left_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel1"/>
        <origin xyz="-0.1 0.22 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </collision>
    </link>

    <joint name="left_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel2"/>
        <origin xyz="0.1 0.22 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- right wheels -->


    <link name="right_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </collision>
    </link>

    <joint name="right_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel1"/>
        <origin xyz="-0.1 -0.22 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.07" length="0.05"/>
            </geometry>
        </collision>
    </link>

    <joint name="right_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel2"/>
        <origin xyz="0.1 -0.22 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- Lidar -->

    <link name="lidar_link">
        <visual>
            <geometry>
                <box size="0.08 0.08 0.08" />
            </geometry>
        </visual>
        <collision>
             <geometry>
                <box size="0.08 0.08 0.08" />
            </geometry>
        </collision>
    </link>

    <joint name="lidar_joint" type="fixed">
        <parent link="robot_base"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.54" rpy="0 0 0"/>
    </joint>

    <gazebo reference="lidar_link">
        <sensor type="ray" name="lidar">
            <pose>0 0 0 0 0 0</pose>
            <update_rate>10</update_rate>
            <ray>
            <scan>
                <horizontal>
                <samples>360</samples>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.15</min>
                <max>12.0</max>
            </range>
            </ray>
            <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
            <ros>
                <remapping>~/out:=scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Camera -->

    <link name="camera_rotator_link">
        <visual>
            <geometry>
                <cylinder radius="0.02" length="0.08"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.02" length="0.08"/>
            </geometry>
        </collision>
    </link>

    <joint name="rotator_joint" type="continuous">
        <parent link="lidar_link"/>
        <child link="camera_rotator_link"/>
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

     <link name="camera_link">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.04" />
            </geometry>
        </visual>
        <collision>
             <geometry>
                <box size="0.04 0.04 0.04" />
            </geometry>
        </collision>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="camera_rotator_link"/>
        <child link="camera_link"/>
        <origin xyz="0.05 0 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="camera_link">
        <sensor type="camera" name="camera">
            <update_rate>30</update_rate>
            <camera>
            <horizontal_fov>1.396</horizontal_fov>  <!-- ~80 degrees -->
            <image>
                <width>640</width>
                <height>480</height>
            </image>
            <clip>
                <near>0.05</near>
                <far>50.0</far>
            </clip>
            </camera>
            <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
            <frame_name>camera_link</frame_name>
            <ros>
                <remapping>image_raw:=camera/image_raw</remapping>
            </ros>
            </plugin>
        </sensor>
    </gazebo>



</robot>