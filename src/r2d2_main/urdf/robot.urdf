<?xml version="1.0"?>

<robot name="r2d2">

    <!-- Chassis and wheels are scaled to 70% of the original size.
         The lidar and camera links keep their original dimensions. -->

    <link name="robot_base">
        <visual>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <geometry>
                <box size="0.28 0.28 0.35" />
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
             <geometry>
                <box size="0.28 0.28 0.35" />
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0.175" rpy="0 0 0"/>
            <mass value="3.0"/>
            <inertia ixx="0.0502" ixy="0" ixz="0"
                     iyy="0.0502" iyz="0"
                     izz="0.0392"/>
        </inertial>
    </link>

    <!-- left wheels -->
    <link name="left_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="left_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel1"/>
        <origin xyz="-0.07 0.154 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="left_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="left_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="left_wheel2"/>
        <origin xyz="0.07 0.154 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>


    <!-- right wheels -->


    <link name="right_wheel1">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="right_wheel1_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel1"/>
        <origin xyz="-0.07 -0.154 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="right_wheel2">
        <visual>
            <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.049" length="0.035"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <inertia ixx="0.000211" ixy="0" ixz="0"
                     iyy="0.000211" iyz="0"
                     izz="0.00036"/>
        </inertial>
    </link>

    <joint name="right_wheel2_joint" type="continuous">
        <parent link="robot_base"/>
        <child link="right_wheel2"/>
        <origin xyz="0.07 -0.154 0" rpy="-1.5707 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <!-- wheel friction (helps the wheels grip the ground plane) -->
    <gazebo reference="left_wheel1"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="left_wheel2"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="right_wheel1"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>
    <gazebo reference="right_wheel2"><mu1>1.0</mu1><mu2>1.0</mu2></gazebo>

    <!-- Differential drive controller (publishes /odom + odom->robot_base TF,
         subscribes to /cmd_vel). Two wheel pairs driven together. -->
    <gazebo>
        <plugin name="diff_drive" filename="libgazebo_ros_diff_drive.so">
            <ros>
                <namespace>/</namespace>
            </ros>

            <num_wheel_pairs>2</num_wheel_pairs>

            <!-- pair 1 -->
            <left_joint>left_wheel1_joint</left_joint>
            <right_joint>right_wheel1_joint</right_joint>
            <!-- pair 2 -->
            <left_joint>left_wheel2_joint</left_joint>
            <right_joint>right_wheel2_joint</right_joint>

            <wheel_separation>0.308</wheel_separation>
            <wheel_separation>0.308</wheel_separation>
            <wheel_diameter>0.098</wheel_diameter>
            <wheel_diameter>0.098</wheel_diameter>

            <max_wheel_torque>20.0</max_wheel_torque>
            <max_wheel_acceleration>1.0</max_wheel_acceleration>

            <command_topic>cmd_vel</command_topic>
            <odometry_topic>odom</odometry_topic>
            <odometry_frame>odom</odometry_frame>
            <robot_base_frame>robot_base</robot_base_frame>

            <publish_odom>true</publish_odom>
            <publish_odom_tf>true</publish_odom_tf>
            <publish_wheel_tf>true</publish_wheel_tf>
        </plugin>
    </gazebo>

    <!-- Lidar (kept at original size) -->

    <link name="lidar_link">
        <visual>
            <geometry>
                <box size="0.08 0.08 0.08" />
            </geometry>
        </visual>
        <collision>
             <geometry>
                <box size="0.08 0.08 0.08" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.0001067" ixy="0" ixz="0"
                     iyy="0.0001067" iyz="0"
                     izz="0.0001067"/>
        </inertial>
    </link>

    <!-- Mounted on top of the (smaller) chassis: base top is now at z=0.35 -->
    <joint name="lidar_joint" type="fixed">
        <parent link="robot_base"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.39" rpy="0 0 0"/>
    </joint>

    <gazebo reference="lidar_link">
        <sensor type="ray" name="lidar">
            <pose>0 0 0 0 0 0</pose>
            <always_on>true</always_on>
            <visualize>true</visualize>
            <update_rate>10</update_rate>
            <ray>
            <scan>
                <horizontal>
                <samples>360</samples>
                <min_angle>-3.14159</min_angle>
                <max_angle>3.14159</max_angle>
                </horizontal>
            </scan>
            <range>
                <min>0.15</min>
                <max>12.0</max>
            </range>
            </ray>
            <plugin name="lidar_plugin" filename="libgazebo_ros_ray_sensor.so">
            <ros>
                <remapping>~/out:=scan</remapping>
            </ros>
            <output_type>sensor_msgs/LaserScan</output_type>
            <frame_name>lidar_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

    <!-- Camera (kept at original size) -->

    <link name="camera_rotator_link">
        <visual>
            <geometry>
                <cylinder radius="0.02" length="0.08"/>
            </geometry>
        </visual>
        <collision>
             <geometry>
                <cylinder radius="0.02" length="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0000317" ixy="0" ixz="0"
                     iyy="0.0000317" iyz="0"
                     izz="0.00001"/>
        </inertial>
    </link>

    <joint name="rotator_joint" type="continuous">
        <parent link="lidar_link"/>
        <child link="camera_rotator_link"/>
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <!-- damping/friction so the joint holds position instead of free-spinning.
             Add a position controller if you want to actively rotate the camera. -->
        <dynamics damping="0.5" friction="0.5"/>
    </joint>

     <link name="camera_link">
        <visual>
            <geometry>
                <box size="0.04 0.04 0.04" />
            </geometry>
        </visual>
        <collision>
             <geometry>
                <box size="0.04 0.04 0.04" />
            </geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.0000133" ixy="0" ixz="0"
                     iyy="0.0000133" iyz="0"
                     izz="0.0000133"/>
        </inertial>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="camera_rotator_link"/>
        <child link="camera_link"/>
        <origin xyz="0.05 0 0" rpy="0 0 0"/>
    </joint>

    <gazebo reference="camera_link">
        <sensor type="camera" name="camera">
            <always_on>true</always_on>
            <update_rate>30</update_rate>
            <camera>
            <horizontal_fov>1.396</horizontal_fov>  <!-- ~80 degrees -->
            <image>
                <width>640</width>
                <height>480</height>
            </image>
            <clip>
                <near>0.05</near>
                <far>50.0</far>
            </clip>
            </camera>
            <plugin name="camera_plugin" filename="libgazebo_ros_camera.so">
            <frame_name>camera_link</frame_name>
            <ros>
                <remapping>image_raw:=camera/image_raw</remapping>
            </ros>
            </plugin>
        </sensor>
    </gazebo>



</robot>
